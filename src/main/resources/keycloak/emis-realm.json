{
  "realm": "emis",
  "enabled": true,
  "displayName": "EMIS Realm",

  "roles": {
    "realm": [
      { "name": "SYSTEM_ADMIN" },
      { "name": "STATE_ADMIN" },
      { "name": "LGA_ADMIN" },
      { "name": "SCHOOL_ADMIN" },
      { "name": "SCHOOL_TEACHER" },
      { "name": "STUDENT" },
      { "name": "PARENT" }
    ]
  },

  "clientScopes": [
    {
      "name": "emis-token",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "claim.name": "roles",
            "access.token.claim": "true"
          }
        },
        {
          "name": "preferred-username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "access.token.claim": "true"
          }
        },
        {
          "name": "schoolCode",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "school_code",
            "claim.name": "schoolCode",
            "jsonType.label": "String",
            "access.token.claim": "true"
          }
        },
        {
          "name": "state",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "state",
            "claim.name": "state",
            "jsonType.label": "String",
            "access.token.claim": "true"
          }
        },
        {
          "name": "lga",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "lga",
            "claim.name": "lga",
            "jsonType.label": "String",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],

  "clients": [


    {
      "clientId": "edge-micro-gateway-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "emis-gateway-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "http://localhost:8081/login/oauth2/code/keycloak"
      ],
      "webOrigins": [
        "http://localhost:8081/*"
      ],
      "defaultClientScopes": [
        "emis-token"
      ]
    },

    {
      "clientId": "emis-school-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "school-service-secret",
      "defaultClientScopes": ["emis-token"],
      "roles": [
        {
          "name": "INTERNAL_SERVICE_READ",
          "description": "Internal service authority for school-service"
        }
      ]
    },


    {
      "clientId": "emis-student-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "student-service-secret",
      "defaultClientScopes": ["emis-token"],
      "roles": [
        {
          "name": "INTERNAL_SERVICE_READ",
          "description": "Internal service authority for school-service"
        }
      ]
    },


    {
      "clientId": "emis-hr-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "hr-service-secret",
      "defaultClientScopes": ["emis-token"],
      "roles": [
        {
          "name": "INTERNAL_SERVICE_READ",
          "description": "Internal service authority for school-service"
        }
      ]
    },


    {
      "clientId": "emis-academic-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "academic-service-secret",
      "defaultClientScopes": ["emis-token"],
      "roles": [
        {
          "name": "INTERNAL_SERVICE_READ",
          "description": "Internal service authority for school-service"
        }
      ]
    },


    {
      "clientId": "emis-facility-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "facility-service-secret",
      "defaultClientScopes": ["emis-token"],
      "roles": [
        {
          "name": "INTERNAL_SERVICE_READ",
          "description": "Internal service authority for school-service"
        }
      ]
    }

  ],

